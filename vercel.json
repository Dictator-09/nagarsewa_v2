{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://nagarsewa-v2.onrender.com/api/$1"
        },
        {
            "source": "/",
            "destination": "/public/index.html"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/public/$1"
        }
    ]
}